# Airtable — waitlist
AIRTABLE_TOKEN=pat_REPLACE_ME
AIRTABLE_BASE_ID=app_REPLACE_ME
AIRTABLE_TABLE_NAME=Waitlist
# Users table for free-download signups (columns: name, email, phone, consent[yes/no])
AIRTABLE_USERS_TABLE=Users

# Resend — fallback signup notifications (used when Airtable is unavailable).
# Keep this in the ROOT .env (not app/, which is the deployed static dir) and
# also add it in the Vercel dashboard → Settings → Environment Variables.
RESEND_API_KEY=re_REPLACE_ME
# Optional overrides:
# RESEND_FROM="Sirus signups <onboarding@resend.dev>"   # must be a Resend-verified sender
# CONTACT_NOTIFY_TO=parhamsepas@gmail.com
